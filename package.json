{
  "name": "rhythm",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:http": "VITE_HTTPS=false vite --host",
    "dev:secure": "vite --host",
    "tunnel": "npx --yes localtunnel --port 5173",
    "share": "bash scripts/share-public.sh",
    "deploy": "npm run build && npx --yes vercel --prod",
    "deploy:netlify": "npm run build && npx --yes netlify-cli deploy --prod --dir=dist",
    "build": "tsc -b && vite build && node scripts/copy-spa-404.mjs",
    "build:app": "CAPACITOR=true tsc -b && CAPACITOR=true vite build",
    "assets": "node scripts/generate-assets.mjs && npx @capacitor/assets generate --iconBackgroundColor \"#0a0e14\" --iconBackgroundColorDark \"#0a0e14\" --splashBackgroundColor \"#0a0e14\" --splashBackgroundColorDark \"#0a0e14\"",
    "cap:sync": "npm run build:app && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:run:android": "npm run cap:sync && npx cap run android",
    "cap:run:ios": "npm run cap:sync && npx cap run ios",
    "lint": "eslint .",
    "preview": "vite preview --host",
    "preview:http": "VITE_HTTPS=false vite preview --host",
    "phone": "npm run build && vite preview --host"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
