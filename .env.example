# Firebase Auth — Project settings → General → Your apps → Web app config
# Also enable Email/Password + Google under Firebase Console → Authentication → Sign-in method
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id
# Testing only — lets email sign-up skip verification emails
VITE_FIREBASE_SKIP_EMAIL_VERIFICATION=true

# Optional — full Spotify playlists/tracks in Focus (Premium + Web Playback SDK)
# https://developer.spotify.com/dashboard → Create app → Settings → Redirect URI:
#   http://localhost:5173/spotify/callback
#   https://rhythm-tau.vercel.app/spotify/callback
VITE_SPOTIFY_CLIENT_ID=
